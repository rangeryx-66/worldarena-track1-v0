@@ -793,4 +793,43 @@ def load_camera_params_from_npy(
         intrinsic[0, 2] = intrinsic[0, 2] * scale - crop_left  # cx (ppx)
         intrinsic[1, 2] = intrinsic[1, 2] * scale - crop_top   # cy (ppy)
     
-    return intrinsic, extrinsics
\ No newline at end of file
+    return intrinsic, extrinsics
+# Compatibility helper for training/train_a2v.py in this checkout.
+def get_vace_traj_maps_with_scaled_intrinsic(
+    pose,
+    w2c,
+    c2w,
+    intrinsic,
+    original_size,
+    target_size,
+    radius_gen_func=None,
+):
+    """Generate VACE trajectory maps after scaling camera intrinsics for stretch resize.
+
+    Args:
+        original_size: (height, width) of the source video.
+        target_size: (height, width) used by the training video tensor.
+    """
+    if isinstance(original_size, torch.Tensor):
+        original_size = original_size.detach().cpu().tolist()
+    if isinstance(target_size, torch.Tensor):
+        target_size = target_size.detach().cpu().tolist()
+    orig_h, orig_w = int(original_size[0]), int(original_size[1])
+    tgt_h, tgt_w = int(target_size[0]), int(target_size[1])
+    intr = intrinsic.clone()
+    intr[..., 0, :] = intr[..., 0, :] * (float(tgt_w) / max(float(orig_w), 1.0))
+    intr[..., 1, :] = intr[..., 1, :] * (float(tgt_h) / max(float(orig_h), 1.0))
+    return get_traj_maps(pose, w2c, c2w, intr, (tgt_h, tgt_w), radius_gen_func=radius_gen_func)
+
+# Compatibility helper for stretch resizing camera intrinsics.
+def adjust_intrinsic_for_resize_stretch(intrinsic, original_size, target_size):
+    if isinstance(original_size, torch.Tensor):
+        original_size = original_size.detach().cpu().tolist()
+    if isinstance(target_size, torch.Tensor):
+        target_size = target_size.detach().cpu().tolist()
+    orig_h, orig_w = int(original_size[0]), int(original_size[1])
+    tgt_h, tgt_w = int(target_size[0]), int(target_size[1])
+    intr = intrinsic.clone()
+    intr[..., 0, :] = intr[..., 0, :] * (float(tgt_w) / max(float(orig_w), 1.0))
+    intr[..., 1, :] = intr[..., 1, :] * (float(tgt_h) / max(float(orig_h), 1.0))
+    return intr
